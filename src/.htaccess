Options +FollowSymlinks
RewriteEngine On

# Toujours rediriger la racine vers une URL avec mots.
RewriteRule ^$ /guerre-iran-accueil.html [R=302,L]

# ----------------------------------------------------------------------
# 1. URL REWRITING
# ----------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME}  !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redirections des anciennes URLs sans mot-cle "guerre".
RewriteRule ^accueil\.html$ /guerre-iran-accueil.html [R=302,L]
RewriteRule ^actualites\.html$ /guerre-iran-actualites.html [R=302,L]
RewriteRule ^contact\.html$ /guerre-iran-contact.html [R=302,L]

# URLs front avec mot-cle obligatoire.
RewriteRule ^guerre-iran-accueil\.html$ index.php?page=accueil [QSA,L]
RewriteRule ^guerre-iran-actualites\.html$ index.php?page=actualites [QSA,L]
RewriteRule ^guerre-iran-contact\.html$ index.php?page=contact [QSA,L]

RewriteRule ^login/?$ login.php [QSA,L]
RewriteRule ^logout/?$ logout.php [QSA,L]
RewriteRule ^admin/?$ admin/index.php [QSA,L]

# Regle type lecon (captures) adaptee au format:
# /articles/guerre-iran-article-12-2-5.html -> id=12&page=2&rubrique=5
RewriteRule ^articles/guerre-iran-article-([0-9]+)-([0-9]+)-([0-9]+)\.html$ article.php?id=$1&page=$2&rubrique=$3 [QSA,L,NC]

# Redirection de l'ancien format article sans mot-cle.
RewriteRule ^articles/article-([0-9]+)-([0-9]+)-([0-9]+)\.html$ /articles/guerre-iran-article-$1-$2-$3.html [R=302,L]

# ----------------------------------------------------------------------
# 2. PERFORMANCE: GZIP COMPRESSION
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
	# Force no compression for already compressed binaries.
	SetEnvIfNoCase Request_URI \
	\.(?:gif|jpe?g|png|webp|avif|ico|zip|gz|bz2|rar|7z|mp4|webm|ogg|pdf)$ no-gzip dont-vary

	AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
	AddOutputFilterByType DEFLATE text/javascript
	AddOutputFilterByType DEFLATE application/javascript application/x-javascript
	AddOutputFilterByType DEFLATE application/json
	AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
	AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
	AddOutputFilterByType DEFLATE application/ld+json
	AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
	AddOutputFilterByType DEFLATE font/woff font/woff2
	AddOutputFilterByType DEFLATE font/ttf font/otf image/svg+xml
</IfModule>

<IfModule mod_headers.c>
	# Compatibility headers for intermediary caches and browsers.
	Header append Vary Accept-Encoding
	Header merge Vary User-Agent
</IfModule>

# ----------------------------------------------------------------------
# 3. PERFORMANCE: CLIENT-SIDE CACHING
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
	ExpiresActive On

	# Static assets cache policy.
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/avif "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType image/x-icon "access plus 1 year"

	ExpiresByType text/css "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType application/javascript "access plus 1 month"
	ExpiresByType application/x-javascript "access plus 1 month"

	ExpiresByType font/woff "access plus 1 year"
	ExpiresByType font/woff2 "access plus 1 year"
	ExpiresByType font/ttf "access plus 1 year"
	ExpiresByType font/otf "access plus 1 year"
	ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

	ExpiresByType application/json "access plus 1 day"
	ExpiresByType application/xml "access plus 1 day"
	ExpiresByType text/xml "access plus 1 day"
	ExpiresByType text/html "access plus 0 seconds"

	ExpiresDefault "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
	# Cache-Control complements Expires for browser and proxy behavior.
	<FilesMatch "\.(?:css|js)$">
		Header set Cache-Control "public, max-age=2592000, immutable"
	</FilesMatch>

	<FilesMatch "\.(?:jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2|ttf|otf|eot)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>

	<FilesMatch "\.(?:json|xml)$">
		Header set Cache-Control "public, max-age=86400"
	</FilesMatch>

	<FilesMatch "\.(?:html|php)$">
		Header set Cache-Control "no-cache, must-revalidate"
	</FilesMatch>
</IfModule>
